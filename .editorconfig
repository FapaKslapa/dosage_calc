root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 4
indent_style = space
insert_final_newline = true
max_line_length = 140
trim_trailing_whitespace = true

[*.{kt,kts}]
ktlint_function_naming_ignore_when_annotated_with = Composable
ij_kotlin_packages_to_use_import_on_demand = androidx.glance.layout
